# aMaze environment configuration
# Copy to .env and fill in values before running docker compose up

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=amaze_dev_password

# ─── API Gateway ─────────────────────────────────────────────────────────────
# Random string used to sign session tokens. Generate with: openssl rand -hex 32
SECRET_KEY=change_me_in_production

# ─── LLM Provider API Keys ───────────────────────────────────────────────────
# At least one is required for agents that make LLM calls.

# OpenAI
OPENAI_API_KEY=

# Any OpenAI-compatible provider (e.g. Groq, Together, Azure OpenAI)
# Set the base URL so the proxy can route correctly.
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=

# ─── aMaze Example Agents — LLM Endpoint ─────────────────────────────────────
# OpenAI-compatible endpoint used by the example agents (summarizer, researcher,
# reviewer). The proxy classifies calls to /v1/... paths as llm_call and enforces
# token budgets and graph steps before forwarding.
LLM_BASE_URL=http://95.173.102.50:8000/v1
LLM_API_KEY=RBAC-LLM
LLM_MODEL=Qwen/Qwen2.5-32B-Instruct

# Ollama (local) — default assumes Ollama running on the host machine
# Use host.docker.internal to reach the host from inside Docker on Mac/Windows.
# On Linux use the host's LAN IP or set up a Docker bridge alias.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ─── Orchestrator ────────────────────────────────────────────────────────────
# Absolute path on the HOST machine where per-session workspaces are created.
# Must be accessible to both the orchestrator container and spawned agent containers.
AGENT_WORKSPACE_HOST_PATH=/tmp/amaze-workspaces
